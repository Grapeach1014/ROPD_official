# ROPD environment template.
#
# Copy this file to `.env` and fill in the values you need. The bundled
# training/*.sh wrappers source the repo `.env` automatically (skip with
# ROPD_SKIP_REPO_DOTENV=true).

# --- Datasets / model paths ------------------------------------------------
DATA_ROOT="datasets/unified"
ROPD_TRAIN_TASK="math/dapo-math-17k"
ROPD_VAL_TASK="math_eval/aime24"


#ROPD_MODEL_PATH="models/Qwen3-4B"
ROPD_MODEL_PATH=/home/work/migoo_ai_public/ruiyu_lu/models/Qwen3-4B
ROPD_CKPT_DIR="checkpoints/ropd"

# Path to the offline teacher answer index (jsonl) consumed by the
# `offline_index` teacher provider during training. Build it with
# `scripts/build_teacher_index.py` (see README "Teacher index").
ROPD_TEACHER_INDEX_PATH="datasets/unified/math/dapo-math-17k/artifacts/teacher_index/shared-teacher-index.jsonl"

# --- Local vLLM judge -----------------------------------------------------
# Started by `bash training/launch_judge_vllm.sh`. Set the model path before
# running it.
#ROPD_JUDGE_MODEL_PATH=""
#ROPD_JUDGE_SERVED_MODEL_NAME="Qwen3-30B-A3B-Instruct-2507"

ROPD_JUDGE_MODEL_PATH=/home/work/migoo_ai_public/ruiyu_lu/models/Qwen3-14B
ROPD_JUDGE_SERVED_MODEL_NAME=Qwen3-14B
ROPD_VLLM_BASE_URL="http://127.0.0.1:18080/v1"
#ROPD_VLLM_MODEL="Qwen3-30B-A3B-Instruct-2507"
ROPD_VLLM_MODEL="Qwen3-14B"
ROPD_VLLM_API_KEY="EMPTY"

# --- Teacher provider (only used when rebuilding the teacher index) -------
# When ROPD_TEACHER_PROVIDER=openai_compatible the rubricator config
# falls back to an OpenAI-compatible endpoint. Leave commented if you only
# train against an existing offline teacher index.
# OPENAI_API_KEY=""
# OPENAI_BASE_URL=""
# ROPD_TEACHER_MODEL="gpt-4o-mini"

OPENAI_API_KEY=EMPTY 
OPENAI_BASE_URL=http://127.0.0.1:18080/v1 
ROPD_TEACHER_MODEL=Qwen3-14B 
ROPD_RUBRICATOR_MODEL=Qwen3-14B 
ROPD_VERIFIER_MODEL=Qwen3-14B


# --- Anthropic / Claude judge ---------------------------------------------
# To route teacher/rubricator/verifier through Claude, set:
# ROPD_JUDGE_PROFILE=claude_compass
# ROPD_JUDGE_PROVIDER=anthropic
# ANTHROPIC_AUTH_TOKEN=""
# ANTHROPIC_BASE_URL="http://inner-api.us.migoo.shopee.io/inbeeai/compass-api/v1"
# ROPD_TEACHER_MODEL="claude-opus-4-6"
# ROPD_RUBRICATOR_MODEL="claude-opus-4-6"
# ROPD_VERIFIER_MODEL="claude-opus-4-6"

# --- Logging --------------------------------------------------------------
# WANDB_ENTITY=""
# WANDB_PROJECT="ROPD"
# WANDB_MODE="online"

# --- Naming --------------------------------------------------------------
EXPERIMENT="ropd"
